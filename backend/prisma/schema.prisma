generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Sesuaikan dengan provider database Anda (sqlite/postgresql/mysql)
}

enum Role {
  ADMIN
  HR
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  LATE
  PERMIT
  ABSENT
}

// Model Shift Kerja untuk pengaturan jam masuk, pulang, dan toleransi keterlambatan
model Shift {
  id               Int      @id @default(autoincrement())
  name             String   // Contoh: Shift Pagi, Jam Kantor Normal
  checkInTime      String   // Format Jam, contoh: "08:00"
  checkOutTime     String   // Format Jam, contoh: "17:00"
  toleranceMinutes Int      @default(15) // Toleransi keterlambatan dalam menit
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users            User[]   // Relasi: Satu shift bisa dimiliki oleh banyak pegawai
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(EMPLOYEE)
  department   String?  // Contoh: IT, HR, Finance, Operasional
  isActive     Boolean  @default(true)
  
  // Relasi ke Shift Kerja
  shiftId      Int?     
  shift        Shift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  attendances  Attendance[]
}

model Attendance {
  id             Int              @id @default(autoincrement())
  userId         Int
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime         
  checkIn        DateTime?        
  checkOut       DateTime?        
  status         AttendanceStatus @default(PRESENT)
  
  // Data Validasi Tambahan (Selfie & GPS)
  checkInLat     Float?           
  checkInLong    Float?           
  checkInSelfie  String?          
  
  checkOutLat    Float?           
  checkOutLong   Float?           
  checkOutSelfie String?          

  createdAt      DateTime         @default(now())
}

model OfficeLocation {
  id        String   @id @default(uuid())
  name      String   @default("Kantor Pusat")
  latitude  Float    // Garis lintang (Latitude)
  longitude Float    // Garis bujur (Longitude)
  radius    Int      // Radius dalam meter (contoh: 100 meter)
  updatedAt DateTime @updatedAt
}